// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Kullanıcı modeli
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  phone       String?
  password    String
  role        UserRole @default(CUSTOMER)
  avatar      String?
  balance     Float    @default(0)
  cardUserKey String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // İlişkiler
  customerRequests Request[]     @relation("CustomerRequests")
  providerProfile  ProviderProfile?
  reviews          Review[]
  messages         Message[]
  payments         Payment[]
  savedCards       SavedCard[]
  transactions     Transaction[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

// Hizmet sağlayıcı profili
model ProviderProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  rating      Float    @default(0)
  totalJobs   Int      @default(0)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  services    Service[]
  requests    Request[] @relation("ProviderRequests")
  reviews     Review[]

  @@map("provider_profiles")
}

// Hizmet kategorileri
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services    Service[]

  @@map("categories")
}

// Hizmetler
model Service {
  id          String   @id @default(cuid())
  providerId  String
  categoryId  String
  title       String
  description String?
  price       Float?
  priceType   PriceType @default(FIXED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  requests    Request[]

  @@map("services")
}

enum PriceType {
  FIXED
  HOURLY
  QUOTE
}

// Talep/İstek modeli
model Request {
  id          String      @id @default(cuid())
  customerId  String
  providerId  String?
  serviceId   String?
  title       String
  description String
  status      RequestStatus @default(PENDING)
  budget      Float?
  location    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?

  customer    User            @relation("CustomerRequests", fields: [customerId], references: [id], onDelete: Cascade)
  provider    ProviderProfile? @relation("ProviderRequests", fields: [providerId], references: [id], onDelete: SetNull)
  service     Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  messages    Message[]
  reviews     Review[]

  @@map("requests")
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Mesajlaşma
model Message {
  id        String   @id @default(cuid())
  requestId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// Değerlendirmeler
model Review {
  id        String   @id @default(cuid())
  requestId String   @unique
  userId    String
  providerId String
  rating    Int      // 1-5 arası
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request   Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// Ödeme kaydı
model Payment {
  id               String        @id @default(cuid())
  userId           String
  conversationId   String        @unique
  paymentId        String?
  amount           Float
  paidAmount       Float
  currency         String        @default("TRY")
  installment      Int           @default(1)
  paymentType      PaymentType
  status           PaymentStatus @default(PENDING)
  cardLast4        String?
  cardBrand        String?
  description      String?
  errorMessage     String?       @db.Text
  dataJson         String?       @db.Text
  ip               String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@map("payments")
}

enum PaymentType {
  BALANCE_DEPOSIT
  PREMIUM_PURCHASE
  SERVICE_PAYMENT
}

enum PaymentStatus {
  PENDING
  AWAITING_3DS
  SUCCESS
  FAILED
}

// Kayıtlı kartlar
model SavedCard {
  id            String   @id @default(cuid())
  userId        String
  cardToken     String
  cardAlias     String?
  cardLast4     String
  cardBrand     String
  cardBankName  String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_cards")
}

// İşlem geçmişi
model Transaction {
  id            String          @id @default(cuid())
  userId        String
  paymentId     String?
  type          TransactionType
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  description   String?
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment       Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

